  <div class="dash-upload-prompt">
    <p class="dash-upload-text">Ready to add your syllabi?</p>
    <a href="/syllabi" class="btn-primary-custom">
      Upload Syllabus
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
<div class="calendar-page position-relative overflow-hidden" style="min-height:100vh; padding-top:100px; padding-bottom:60px;">

  <!-- background flare -->
  <div style="
    position:absolute;
    inset:0;
    z-index:0;
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 90, 90, 0.14), transparent 25%),
      radial-gradient(circle at 82% 18%, rgba(60, 120, 255, 0.14), transparent 30%),
      radial-gradient(circle at 30% 78%, rgba(180, 255, 120, 0.10), transparent 30%),
      radial-gradient(circle at 75% 72%, rgba(255, 210, 70, 0.10), transparent 30%),
      linear-gradient(180deg, rgba(7,7,12,0.96) 0%, rgba(5,5,8,1) 100%);
  "></div>

  <div class="container position-relative" style="z-index:2;">
    <div class="row g-4">

      <!-- LEFT: MONTH -->
      <div class="col-lg-5">
        <div style="
          background: rgba(16,16,28,0.72);
          border: 1px solid rgba(255,255,255,0.05);
          backdrop-filter: blur(14px);
          border-radius: 28px;
          padding: 28px;
          box-shadow: 0 20px 60px rgba(0,0,0,0.45);
        ">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <button id="prevMonth" style="background:none;border:none;color:#fff;font-size:1.4rem;cursor:pointer;padding:0 8px;">&#8249;</button>
            <h2 class="text-light mb-0" id="calTitle"></h2>
            <button id="nextMonth" style="background:none;border:none;color:#fff;font-size:1.4rem;cursor:pointer;padding:0 8px;">&#8250;</button>
          </div>
          <div id="calWeeks"></div>
        </div>
      </div>

      <!-- RIGHT: DAILY VIEW -->
      <div class="col-lg-7">
        <div style="
          background: rgba(16,16,28,0.72);
          border: 1px solid rgba(255,255,255,0.05);
          backdrop-filter: blur(14px);
          border-radius: 28px;
          padding: 28px;
          box-shadow: 0 20px 60px rgba(0,0,0,0.45);
        ">
          <h2 class="text-light mb-1">Daily View</h2>
          <div id="selected-date" style="color:#f09a74; font-weight:600;"></div>
          <div id="stress-level" class="mt-2 mb-4"></div>
          <div id="daily-events" style="
            border-left: 2px solid rgba(255,255,255,0.08);
            padding-left: 20px;
            transition: all 0.3s ease;
          "></div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const totalClasses = {{totalClasses}};
  const events = {{{eventsJson}}};

  const POINTS_BY_TYPE = { EXAM: 10, PROJ: 6, LAB: 4, QUIZ: 3, HW: 2 };
  const DAY_THRESHOLDS  = { hard: 10, medium: 5 };
  const WEEK_THRESHOLDS_BY_CLASS_COUNT = {
    1: { easyMax: 10, mediumMax: 14 },
    2: { easyMax: 13, mediumMax: 17 },
    3: { easyMax: 16, mediumMax: 20 },
    4: { easyMax: 19, mediumMax: 23 },
    5: { easyMax: 22, mediumMax: 26 },
    6: { easyMax: 25, mediumMax: 29 }
  };
  const DIFFICULTY_STYLE = {
    Easy:   { color: '#34d17b', textClass: 'text-success', bg: 'linear-gradient(135deg,rgba(120,255,120,0.16),rgba(120,255,120,0.05))' },
    Medium: { color: '#ffd24d', textClass: 'text-warning', bg: 'linear-gradient(135deg,rgba(255,210,70,0.22),rgba(255,210,70,0.05))' },
    Hard:   { color: '#ff4d57', textClass: 'text-danger',  bg: 'linear-gradient(135deg,rgba(255,80,80,0.22),rgba(255,80,80,0.05))' }
  };
  const COLOR_MAP = { HW: '#2f6fff', QUIZ: '#9BFF00', EXAM: '#ff4d57', LAB: '#ffd24d', PROJ: '#c77dff' };
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];

  const today = new Date();
  let viewYear  = today.getFullYear();
  let viewMonth = today.getMonth();

  function isoKey(y, m, d) {
    const dt = new Date(y, m, d);
    return `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
  }

  function pointsForDate(dateStr) {
    return (events[dateStr] || []).reduce((sum, e) => sum + (POINTS_BY_TYPE[e.type] || 0), 0);
  }

  function classifyDay(pts)  {
    return pts > DAY_THRESHOLDS.hard ? 'Hard' : pts > DAY_THRESHOLDS.medium ? 'Medium' : 'Easy';
  }

  function classifyWeek(pts, n) {
    const k = Math.min(6, Math.max(1, n));
    const { easyMax, mediumMax } = WEEK_THRESHOLDS_BY_CLASS_COUNT[k];
    return pts > mediumMax ? 'Hard' : pts >= easyMax ? 'Medium' : 'Easy';
  }

  function buildCalendar() {
    document.getElementById('calTitle').textContent = monthNames[viewMonth] + ' ' + viewYear;

    const firstDow    = new Date(viewYear, viewMonth, 1).getDay();
    const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
    const prevDays    = new Date(viewYear, viewMonth, 0).getDate();

    // Build flat array of calendar cells
    const cells = [];
    for (let i = firstDow - 1; i >= 0; i--)
      cells.push({ day: prevDays - i, offset: -1 });
    for (let d = 1; d <= daysInMonth; d++)
      cells.push({ day: d, offset: 0 });
    while (cells.length % 7)
      cells.push({ day: cells.length - daysInMonth - firstDow + 1, offset: 1 });

    const container = document.getElementById('calWeeks');
    container.innerHTML = '';

    for (let w = 0; w < cells.length / 7; w++) {
      const week = cells.slice(w * 7, w * 7 + 7);

      const weekPts = week.reduce((sum, c) => {
        if (c.offset !== 0) return sum;
        return sum + pointsForDate(isoKey(viewYear, viewMonth, c.day));
      }, 0);
      const diff  = classifyWeek(weekPts, totalClasses);
      const style = DIFFICULTY_STYLE[diff];

      const weekDiv = document.createElement('div');
      weekDiv.className = 'mb-3 p-3';
      weekDiv.style.cssText = `border-radius:18px; background:${style.bg};`;

      const header = document.createElement('div');
      header.className = 'd-flex justify-content-between mb-2';
      header.innerHTML = `<span class="text-light">Week ${w + 1}</span><span class="fw-bold ${style.textClass}">${diff}</span>`;
      weekDiv.appendChild(header);

      const daysRow = document.createElement('div');
      daysRow.className = 'd-flex justify-content-between';

      week.forEach(c => {
        const span = document.createElement('span');
        if (c.offset !== 0) {
          span.style.color = 'rgba(255,255,255,0.2)';
          span.textContent = c.day;
        } else {
          const key       = isoKey(viewYear, viewMonth, c.day);
          const hasEvents = !!(events[key] && events[key].length);
          const isToday   = c.day === today.getDate() && viewMonth === today.getMonth() && viewYear === today.getFullYear();

          span.style.cursor = 'pointer';
          span.style.color  = hasEvents ? '#ffd24d' : 'rgba(255,255,255,0.55)';
          if (isToday) { span.style.fontWeight = 'bold'; span.style.textDecoration = 'underline'; }
          span.textContent = c.day;
          span.addEventListener('click', () => renderDay(key));
        }
        daysRow.appendChild(span);
      });

      weekDiv.appendChild(daysRow);
      container.appendChild(weekDiv);
    }
  }

  function renderDay(dateStr) {
    const [y, m, d]  = dateStr.split('-').map(Number);
    const monthLabel = monthNames[m - 1];
    document.getElementById('selected-date').textContent = `${monthLabel} ${d}, ${y}`;

    const container = document.getElementById('daily-events');
    const dayEvents = events[dateStr] || [];

    container.style.opacity   = 0;
    container.style.transform = 'translateY(10px)';
    setTimeout(() => { container.style.opacity = 1; container.style.transform = 'translateY(0)'; }, 100);

    container.innerHTML = '';
    if (dayEvents.length === 0) {
      container.innerHTML = `<div class="text-muted">No assignments due.</div>`;
    } else {
      dayEvents.forEach(e => {
        const dot = COLOR_MAP[e.type] || '#888';
        container.innerHTML += `
          <div class="mb-4 position-relative">
            <div style="position:absolute;left:-28px;top:6px;width:10px;height:10px;border-radius:50%;background:${dot};box-shadow:0 0 10px ${dot};"></div>
            <div class="text-light fw-bold">${e.title}</div>
            <small class="text-muted">${e.time || 'No time set'}</small>
          </div>`;
      });
    }

    const pts  = dayEvents.reduce((s, e) => s + (POINTS_BY_TYPE[e.type] || 0), 0);
    const diff = classifyDay(pts);
    const s    = DIFFICULTY_STYLE[diff];
    document.getElementById('stress-level').innerHTML = `
      <span style="background:${s.color};padding:6px 14px;border-radius:20px;font-size:0.85rem;color:white;">
        ${diff} &middot; ${pts} pts
      </span>`;
  }

  document.getElementById('prevMonth').addEventListener('click', () => {
    viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; }
    buildCalendar();
  });
  document.getElementById('nextMonth').addEventListener('click', () => {
    viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; }
    buildCalendar();
  });

  buildCalendar();
  renderDay(isoKey(today.getFullYear(), today.getMonth(), today.getDate()));
</script>
