{{> funcalbg}}
{{{html}}}
<div class="content-layer">
    <section class="hero-section">
        <div class="hero-inner fade-up">
            <h1 class="hero-title">
                Login to Your Account
            </h1>
            <p class="hero-subtitle">
                Sign in to access your syllabi and calendar.
            </p>
            <form class="register-form d-flex flex-column gap-3" action="/login" method="POST">
                <input type="text" name="username" placeholder="Username" required class="form-control form-control-lg">
                <input type="password" name="password" placeholder="Password" required class="form-control form-control-lg">
                <button type="submit" class="btn-primary-custom mt-3">Login</button>
                <p class="mt-2">Need to create an account? <a style="color: var(--terracotta);" href="/register">Register here</a>.</p>
            </form>
        </div>
    </section>