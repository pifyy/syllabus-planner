<div class="content-layer">
  <div class="sched-page" style="padding-top:100px;padding-left:40px;padding-right:40px;max-width:800px;margin:0 auto">

    <div class="sched-header">
      <div>
        <h1 class="sched-title">Study Plan</h1>
        <p class="sched-sub">AI-recommended start dates based on your upcoming deadlines.</p>
      </div>
      <button class="btn-primary-custom sched-refresh-btn" id="refreshBtn">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M2 8a6 6 0 1 0 1.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M2 4v4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Refresh
      </button>
    </div>

    <!-- Loading -->
    <div class="sched-loading" id="schedLoading" style="display:none">
      <div class="sched-pulse-list">
        <div class="sched-pulse-row"></div>
        <div class="sched-pulse-row"></div>
        <div class="sched-pulse-row short"></div>
      </div>
      <p class="sched-loading-label">Reading your assignments…</p>
    </div>

    <!-- No assignments -->
    <div class="sched-empty" id="schedEmpty" style="display:none">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" style="opacity:0.3">
        <rect x="6" y="10" width="36" height="32" rx="4" stroke="currentColor" stroke-width="2"/>
        <path d="M6 20h36" stroke="currentColor" stroke-width="2"/>
        <path d="M16 4v12M32 4v12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <p>No upcoming assignments found. <a href="/syllabi">Upload a syllabus</a> to get started.</p>
    </div>

    <!-- Error -->
    <div class="sched-error-msg" id="schedError" style="display:none"></div>

    <!-- Results -->
    <div class="sched-results" id="schedResults" style="display:none">
      <div class="sched-cards" id="schedCards"></div>
    </div>

  </div>
</div>

<script>
  window.SCHED_ASSIGNMENTS = {{{assignmentsJson}}};
</script>
<script src="/assets/js/schedule.js"></script>
