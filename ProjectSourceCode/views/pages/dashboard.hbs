<div class="content-layer">
  <div class="dashboard-layout">
    <!-- sample calendar layout with random events HARDCODED --> 
    <div class="dash-cal-panel">
      <div class="dash-panel-label">Monthly View</div>
      <div class="dash-cal-card">
        <div class="dash-cal-header">
          <button class="dash-cal-nav" id="prevMonth">&#8249;</button>
          <span class="dash-cal-title" id="calMonthTitle"></span>
          <button class="dash-cal-nav" id="nextMonth">&#8250;</button>
        </div>
        <div class="dash-cal-weekdays">
          <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
        </div>
        <div class="dash-cal-days" id="dashCalDays"></div>
      </div>
    </div>
    <div class="dash-timeline-panel">
      <div class="dash-panel-label">Week at a Glance</div>
      <div class="dash-week-strip" id="dashWeekStrip"></div>
      <div class="preview-card">
        <div class="preview-topbar">
          <div class="dot r"></div>
          <div class="dot y"></div>
          <div class="dot g"></div>
          <span class="preview-topbar-label">Daily Timeline</span>
        </div>
        <div class="preview-body">
        </div>
      </div>
    </div>

  </div>
  <div class="dash-upload-prompt">
    <p class="dash-upload-text">Ready to add your syllabi?</p>
    <a href="/syllabi" class="btn-primary-custom">
      Upload Syllabus
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</div>
<script src="/assets/js/calendar.js"></script>