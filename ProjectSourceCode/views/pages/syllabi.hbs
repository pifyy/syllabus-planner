<div class="content-layer">
  <div class="syllabi-layout">

    <!-- ── Left: Upload Panel ── -->
    <div class="syllabi-upload-panel">
      <div class="dash-panel-label">Upload Syllabi</div>

      <div class="upload-zone" id="uploadZone">
        <div class="upload-icon">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <path d="M20 26V14M20 14L14 20M20 14L26 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10 28a8 8 0 01-2-15.3A10 10 0 0128.3 14 6 6 0 0132 26" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <form action="/syllabi/upload" method="POST" enctype="multipart/form-data">
          <h3 class="upload-title">Drop your syllabus here</h3>
          <p class="upload-sub">PDF, DOCX, or image - we handle the rest</p>
          <label class="btn-primary-custom upload-btn" for="fileInput">
            Browse Files
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </label>
          <input type="file" name="syllabusFile" id="fileInput" accept=".pdf,.docx,.png,.jpg,.jpeg" style="display:none">
          <p class="upload-hint">Supports PDF · DOCX · PNG · JPG</p>
          <button class="btn-primary-custom" type="submit">Upload</button>
        </form>
      </div>

      <div class="upload-processing" id="uploadProcessing">
        <div class="processing-bar"><div class="processing-fill" id="processingFill"></div></div>
        <span class="processing-label" id="processingLabel">Reading file…</span>
      </div>

      <div class="upload-success" id="uploadSuccess">
        <div class="success-icon">✓</div>
        <span>Syllabus added!</span>
      </div>

      <div class="upload-file-list" id="uploadFileList"></div>
    </div>

    <!-- ── Right: Syllabi View Panel ── -->
    <div class="syllabi-view-panel">
      <div class="dash-panel-label">Your Syllabi</div>

      {{#if hasClasses}}
      <div class="syllabi-tabs">

        <!-- Tab buttons — one per enrolled class -->
        <div class="tab-bar" id="tabBar">
          {{#each classes}}
          <button class="tab-btn{{#if isFirst}} active{{/if}}" data-tab="{{classID}}">{{className}}</button>
          {{/each}}
        </div>

        <!-- Tab panels — one per enrolled class -->
        <div class="tab-panels">
          {{#each classes}}
          <div class="tab-panel{{#if isFirst}} active{{/if}}" id="tab-{{classID}}">

            <div class="syllabus-header">
              <div>
                <h2 class="syllabus-title">{{className}}</h2>
                <p class="syllabus-code">{{classCode}} · {{term}}</p>
              </div>
              <div class="preview-tag assign">{{assignments.length}} Items</div>
            </div>

            <div class="syllabus-meta">
              <div class="meta-item">
                <span class="meta-label">Professor</span>
                <span class="meta-value">{{professor}}</span>
              </div>
              {{#if scheduleStr}}
              <div class="meta-item">
                <span class="meta-label">Schedule</span>
                <span class="meta-value">{{scheduleStr}}</span>
              </div>
              {{/if}}
              {{#if location}}
              <div class="meta-item">
                <span class="meta-label">Room</span>
                <span class="meta-value">{{location}}</span>
              </div>
              {{/if}}
              {{#if textbook}}
              <div class="meta-item">
                <span class="meta-label">Textbook</span>
                <span class="meta-value">{{textbook}}</span>
              </div>
              {{/if}}
            </div>

            <div class="event-list-label">Assignments</div>
            {{#if assignments}}
            <div class="preview-card">
              <div class="preview-body">
                {{#each assignments}}
                <div class="preview-row">
                  <div class="preview-dot {{dotClass}}"></div>
                  <div class="preview-text">
                    <span>{{name}}</span>
                    <small>
                      {{#if dueDate}}{{dueDate}}{{#if dueTime}} · {{dueTime}}{{/if}}{{else}}Repeating{{/if}}
                    </small>
                  </div>
                  <div class="preview-tag {{tagClass}}">{{type}}</div>
                </div>
                {{/each}}
              </div>
            </div>
            {{else}}
            <p class="upload-hint">No assignments found for this class.</p>
            {{/if}}

          </div>
          {{/each}}
        </div>
      </div>

      {{else}}
      <div style="padding: 2rem; text-align: center; color: var(--text-muted, #888);">
        <p>No syllabi uploaded yet. Upload a syllabus to get started.</p>
      </div>
      {{/if}}

    </div>
  </div>
</div>
<script src="/assets/js/syllabi.js"></script>
