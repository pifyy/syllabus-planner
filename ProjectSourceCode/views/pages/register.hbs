{{{html}}}
<div class="content-layer">
    <section class="hero-section">
        <div class="hero-inner fade-up">
            <h1 class="hero-title">
                Create an Account
            </h1>
            <p class="hero-subtitle">
                Sign up to start uploading your syllabi and creating your unified timeline.
            </p>
            <!-- fun error handling for the user -->
            {{#if error}}
                <p class="text-danger">{{error}}</p>
            {{/if}}
            <form class="register-form d-flex flex-column gap-3" action="/register" method="POST">
                <input type="text" name="username" placeholder="Username" required class="form-control form-control-lg">
                <input type="email" name="email" placeholder="Email" required class="form-control form-control-lg">
                <input type="password" name="password" placeholder="Password" required class="form-control form-control-lg">
                <button type="submit" class="btn-primary-custom mt-3">Register</button>
                <p class="mt-2">Already have an account? <a style="color: var(--terracotta);" href="/login">Log in here</a>.</p>
            </form>
        </div>
    </section>