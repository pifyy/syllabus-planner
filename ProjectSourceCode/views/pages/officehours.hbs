<div class="content-layer">
  <div class="dashboard-layout">

    <!-- ── Left: Class list ── -->
    <div class="dash-cal-panel">
      <div class="dash-panel-label">Your Classes</div>

      {{#if hasClasses}}
      <div class="oh-class-list" id="ohClassList">
        {{#each classes}}
        <div class="oh-class-btn{{#if isFirst}} active{{/if}}" data-target="{{classID}}">
          <span class="oh-class-name">{{className}}</span>
          {{#if classCode}}<span class="oh-class-code">{{classCode}}</span>{{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="oh-empty-hint">No classes found. Upload a syllabus to get started.</p>
      {{/if}}
    </div>

    <!-- ── Right: Office hours detail ── -->
    <div class="dash-timeline-panel">
      <div class="dash-panel-label">Office Hours</div>

      {{#if hasClasses}}
        {{#each classes}}
        <div class="oh-panel{{#if isFirst}} active{{/if}}" id="oh-{{classID}}">

          <div class="syllabus-header">
            <div>
              <h2 class="syllabus-title">{{className}}</h2>
              <p class="syllabus-code">{{classCode}}{{#if classCode}} · {{/if}}{{term}}</p>
            </div>
          </div>

          <div class="syllabus-meta">

            <div class="meta-item">
              <span class="meta-label">Professor</span>
              <span class="meta-value">{{professor}}</span>
            </div>

            {{#if ohStr}}
            <div class="meta-item">
              <span class="meta-label">Office Hours</span>
              <span class="meta-value">
                {{ohStr}}{{#if ohRemote}} &nbsp;<span class="oh-remote-badge">Remote</span>{{/if}}
              </span>
            </div>
            {{/if}}

            {{#if ohLocation}}
            <div class="meta-item">
              <span class="meta-label">OH Location</span>
              <span class="meta-value">{{ohLocation}}</span>
            </div>
            {{/if}}

            {{#if email}}
            <div class="meta-item">
              <span class="meta-label">Email</span>
              <span class="meta-value">
                <a href="mailto:{{email}}" class="oh-email-link">{{email}}</a>
              </span>
            </div>
            {{/if}}

            {{#if scheduleStr}}
            <div class="meta-item">
              <span class="meta-label">Class Schedule</span>
              <span class="meta-value">{{scheduleStr}}</span>
            </div>
            {{/if}}

          </div>

          {{#unless ohStr}}
          <div class="oh-no-hours">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" style="color:var(--text-muted)">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <p>No office hours on record for this class.</p>
          </div>
          {{/unless}}

        </div>
        {{/each}}

      {{else}}
      <div class="oh-no-hours">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" style="color:var(--text-muted)">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <p>No syllabi uploaded yet. Upload a syllabus to see office hours here.</p>
      </div>
      {{/if}}

    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.oh-class-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.oh-class-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.oh-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('oh-' + btn.dataset.target).classList.add('active');
    });
  });
</script>
