<div class="content-layer">
  <div class="dashboard-layout">

    <div class="dash-cal-panel">
      <div class="dash-panel-label">Your Classes</div>
      <div class="oh-class-list" id="ohClassList">
        {{#if hasClasses}}
          {{#each classes}}
            <div class="oh-class-btn {{#if isFirst}}active{{/if}}" data-target="{{slug}}">{{className}}</div>
          {{/each}}
        {{else}}
          <p class="no-classes-msg">No classes enrolled.</p>
        {{/if}}
      </div>
    </div>

    <div class="dash-timeline-panel">
      <div class="dash-panel-label">Office Hours</div>

      {{#if hasClasses}}
        {{#each classes}}
          <div class="oh-panel {{#if isFirst}}active{{/if}}" id="oh-{{slug}}">
            <div class="syllabus-header">
              <div>
                <h2 class="syllabus-title">{{className}}</h2>
                <p class="syllabus-code">{{classCode}} · {{term}}</p>
              </div>
            </div>
            <div class="syllabus-meta">
              <div class="meta-item"><span class="meta-label">Professor</span><span class="meta-value">{{professor}}</span></div>
              <div class="meta-item"><span class="meta-label">Office Hours</span><span class="meta-value">{{ohStr}}</span></div>
              {{#each officeHours}}
                <div class="meta-item">
                  <span class="meta-label">{{dayLabel}} {{startTime}}–{{endTime}}</span>
                  <span class="meta-value">{{location}}{{#if remote}} (Remote){{/if}}</span>
                </div>
              {{/each}}
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="no-classes-msg">Upload a syllabus to see office hours.</p>
      {{/if}}

    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.oh-class-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.oh-class-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.oh-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('oh-' + btn.dataset.target).classList.add('active');
    });
  });
</script>
