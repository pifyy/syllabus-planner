<script>
  document.querySelectorAll('.oh-class-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.oh-class-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.oh-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('oh-' + btn.dataset.target).classList.add('active');
    });
  });
</script>